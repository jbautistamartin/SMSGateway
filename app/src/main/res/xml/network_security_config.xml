<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Política de seguridad de red para el SMS Gateway corporativo.
        - Tráfico cleartext (HTTP) deshabilitado globalmente.
        - Solo se permiten conexiones HTTPS.
        - Para redes corporativas con certificados privados, añadir un <domain-config>
          con el certificado CA de la empresa en res/raw/.
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Confiar en las CAs del sistema (incluye las corporativas instaladas en el dispositivo) -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Ejemplo para CA corporativa privada (descomentar y añadir certificado en res/raw/):
    <domain-config>
        <domain includeSubdomains="true">api.empresa.com</domain>
        <trust-anchors>
            <certificates src="@raw/ca_corporativa" />
        </trust-anchors>
    </domain-config>
    -->
</network-security-config>
